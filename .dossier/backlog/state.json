  "context": {
    "glossary": [
      {
        "term": "deployment cell",
        "definition": "The canonical multi-service runtime boundary that hosts the Polyphony core, PostgreSQL, model organs, and workshop workers.",
        "aliases": [
          "cell"
        ]
      },
      {
        "term": "identity-bearing core",
        "definition": "The single long-lived Polyphony runtime that owns subject continuity, bounded action, and workflow orchestration.",
        "aliases": [
          "polyphony core"
        ]
      },
      {
        "term": "organ",
        "definition": "A bounded non-personal model or capability surface used by the core as a cognitive or operational organ.",
        "aliases": [
          "model organ"
        ]
      }
    ],
    "key_strategy": {
      "item_key_space": "Preserve legacy CF-* seam identifiers as stable backlog item keys during migration to the unified dossier-engineer runtime.",
      "delivery_state_rule": "Legacy intaken maps to implemented by explicit operator instruction; confirmed maps to planned; remaining candidate seams stay defined unless a carried migration gap blocks them.",
      "source_traceability": "Architecture and legacy planning inputs stay attached through registered source IDs, while current truth is read from dossier-engineer backlog state after packet apply."
    },
    "target_system": [
      {
        "area": "runtime",
        "summary": "One long-lived identity-bearing agent runs in ticks and owns bounded action, continuity, and workflow orchestration.",
        "services": [
          "polyphony-core"
        ],
        "public_http": false
      },
      {
        "area": "state",
        "summary": "PostgreSQL is the canonical state kernel while the body and skills live in a Git-governed workspace.",
        "stores": [
          "postgres",
          "git-workspace"
        ],
        "public_http": false
      },
      {
        "area": "models",
        "summary": "Local model services act as organs behind the runtime rather than separate personalities.",
        "services": [
          "vllm-fast",
          "vllm-deep",
          "vllm-pool"
        ],
        "public_http": false
      },
      {
        "area": "workshop",
        "summary": "Datasets, training, evaluation, and bounded promotion stay on the canonical workshop/runtime boundary.",
        "services": [
          "workshop"
        ],
        "public_http": false
      },
      {
        "area": "operations",
        "summary": "Verification and deployment use the canonical pnpm toolchain, root quality gates, and containerized smoke path.",
        "commands": [
          "pnpm quality:fix",
          "pnpm quality:check",
          "pnpm smoke:cell"
        ],
        "public_http": false
      }
    ],
