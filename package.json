{
  "name": "yaagi",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "test": "node --experimental-strip-types --experimental-test-module-mocks --test",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "db:bootstrap": "node --experimental-strip-types packages/db/src/cli/bootstrap.ts",
    "cell:up": "env DOCKER_BUILDKIT=0 COMPOSE_DOCKER_CLI_BUILD=0 docker compose -f infra/docker/compose.yaml up -d --build --wait",
    "cell:down": "docker compose -f infra/docker/compose.yaml down --volumes --remove-orphans",
    "smoke:cell": "node --experimental-strip-types --test infra/docker/deployment-cell.smoke.ts",
    "sync:index": "node scripts/sync-index.mjs",
    "lint:dossiers": "node scripts/lint-dossiers.mjs",
    "coverage:audit": "node scripts/coverage-audit.mjs",
    "dependency:graph": "node scripts/dependency-graph.mjs"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
