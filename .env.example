# Secret-bearing local overrides for local Node/Docker runs.
# Canonical local-secret entrypoints: `pnpm cell:up:local` and `pnpm smoke:cell:local`.
# Application code continues to read `process.env`.

YAAGI_TELEGRAM_ENABLED=false
YAAGI_TELEGRAM_BOT_TOKEN=
# Optional external secret-file path for container/production launches.
YAAGI_TELEGRAM_BOT_TOKEN_FILE=
YAAGI_TELEGRAM_ALLOWED_CHAT_IDS=
YAAGI_TELEGRAM_API_BASE_URL=https://api.telegram.org
# Preferred secret-file path for local/container Gemma materialization.
YAAGI_HF_TOKEN_FILE=
# Compatibility fallback; local infra automation will materialize this into a temp secret file.
YAAGI_HF_TOKEN=
YAAGI_VLLM_FAST_SELECTED_CANDIDATE_ID=
VLLM_FAST_BASE_IMAGE=vllm/vllm-openai-rocm:gemma4
YAAGI_DEEP_MODEL_BASE_URL=http://127.0.0.1:8001/v1
YAAGI_POOL_MODEL_BASE_URL=http://127.0.0.1:8002/v1
